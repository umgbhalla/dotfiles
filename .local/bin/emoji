#!/bin/sh
# finds and copies a text emoji to the clipboard

emoji=$(cat "${XDG_DATA_HOME}/emojis" | sed -e 's/\ +#/\\t#/' | shellmenu | \
  awk -F '#' '{printf "%s",$1}')

if [ -n "$emoji" ]; then
  echo $emoji | tr -d '\n' | xclip -selection clipboard
  $NOTIFICATION_MANAGER "Copied to clipboard."
fi
