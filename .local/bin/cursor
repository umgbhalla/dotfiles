#!/bin/sh
# toggles the display of the cursor for people who are annoyed by cursors most of the time

cursorHideX="0"
cursorHideY="$RES_HEIGHT"

if [ -z "${1}" ]; then
  echo "${RED}USAGE: cursor [show | hide]${NC}"
  exit 1
fi

if ! command -v xinput > /dev/null; then
  echo "${RED}ERROR: xorg-xinput is required${NC}"
  exit 1
fi

if ! command -v xdotool > /dev/null; then
  echo "${RED}ERROR: xdotool is required${NC}"
  exit 1
fi

devicesIndex=0
raw="$(xinput)"

mouseStr="$(echo "$raw" | \
  grep -i "mouse.*id=" | \
  grep -o "id=.*" | \
  tr '[:blank:]' ';' | \
  cut -d ';' -f 1 | \
  cut -d '=' -f 2
  )"

pointerStr="$(echo "$raw" | \
  grep -i "pointer.*id=" | \
  grep -o "id=.*" | \
  tr '[:blank:]' ';' | \
  cut -d ';' -f 1 | \
  cut -d '=' -f 2
  )"

touchpadStr="$(echo "$raw" | \
  grep -i "touchpad.*id=" | \
  grep -o "id=.*" | \
  tr '[:blank:]' ';' | \
  cut -d ';' -f 1 | \
  cut -d '=' -f 2
  )"

for mouse in $mouseStr; do
  devices[devicesIndex]="$mouse"
  devicesIndex=$devicesIndex+1
done

for pointer in $pointerStr; do
  devices[devicesIndex]="$pointer"
  devicesIndex=$devicesIndex+1
done

for touchpad in $touchpadStr; do
  devices[devicesIndex]="$touchpad"
  devicesIndex=$devicesIndex+1
done

case "${1}" in
  "show")
    for device in "${devices[@]}"; do
      xinput enable "$device" 2>/dev/null
      xsetroot -cursor_name left_ptr
    done
    ;;
  "hide")
    xdotool mousemove "$cursorHideX" "$cursorHideY"
    for device in "${devices[@]}"; do
      xinput disable "$device" 2>/dev/null
      case "$OS" in
        "$OS_OPENBSD") xsetroot -cursor_name hand1 ;;
        "$OS_LINUX")
          # Adwaita
          xsetroot -cursor_name lr_angle
          ;;
      esac
    done
    ;;
esac
