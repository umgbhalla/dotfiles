#!/bin/sh
# manages any form of screen capturing or recording
# in addition to audio capturing and recording.

# --------------------------------------------------------------------------
# environment
# --------------------------------------------------------------------------

# output directories
snapOutputDir="$HOME/Pictures"
captureOutputDir="$HOME/Videos"
if [ -n "$1" ]; then
  mkdir -p "$snapOutputDir"
  mkdir -p "$captureOutputDir"
fi

# filename date format
datefmt="$(\date +%y-%m-%d_%H:%M:%S)"

cursorHideX="0"
cursorHideY="$RES_HEIGHT"

# recording status temporary file path
screenPid="${TMP_DIR}/screenPid"

notify() {
  $NOTIFICATION_MANAGER "$1"
}

# --------------------------------------------------------------------------
# capture
# --------------------------------------------------------------------------

screenCapture() {
  if [ ! -f "${screenPid}" ]; then
    notify "Screen capture starting."

    case $OS in
      $OS_LINUX)
        ffmpeg \
          -f x11grab -video_size "${RES_WIDTH}x${RES_HEIGHT}" \
          -i "$DISPLAY" \
          -f alsa -i default -c:v libx264 \
          -preset ultrafast -c:a aac \
          "$captureOutputDir/screencapture-${datefmt}.mp4" &
        ;;
      *)
        ffmpeg \
          -f x11grab -i $DISPLAY \
          -c:v libx264 -preset ultrafast -c:a aac \
          "$captureOutputDir/screencapture-${datefmt}.mp4" &
        ;;
    esac

    echo $! > "${screenPid}"
    $BAR_UPDATE
  else
    echo -e "${RED}Error: capture already in progress.${NC}"
  fi
}

# --------------------------------------------------------------------------
# crop
# --------------------------------------------------------------------------

screenCrop() {
  output="${snapOutputDir}/snap-${datefmt}.png"
  geometry="$(slop)"

  if [ -z "${geometry}" ]; then
    echo "${RED}Error: invalid dimensions.${NC}"
  else
    dim="$(echo "${geometry}" | cut -d"+" -f1)"
    x="$(echo "${geometry}" | cut -d"+" -f2)"
    y="$(echo "${geometry}" | cut -d"+" -f3)"

    # must be evaluated (eval) to bring the variables to local scope
    eval "$(xdotool getmouselocation --shell)"
    xdotool mousemove --sync "$cursorHideX" "$cursorHideY"

    ffmpeg -f x11grab -video_size "${dim}" -i "${DISPLAY}+${x},${y}" -vframes 1 "${output}"

    xdotool mousemove --sync "$X" "$Y"
    xclip -selection clip -t image/png "${output}"
    notify "Cropped screenshot taken."
  fi
}

# --------------------------------------------------------------------------
# gif
# --------------------------------------------------------------------------

screenGif() {
  if [ ! -f "${screenPid}" ]; then
    output="${captureOutputDir}/gif-${datefmt}.gif"
    geometry="$(slop)"
    fps="7"
    # largest possible width to incentivize small area recordings
    maxRatio="900"

    if [ -z ${geometry} ]; then
      echo "${RED}Error: invalid dimensions.${NC}"
    else
      dim="$(echo "${geometry}" | cut -d"+" -f1)"
      x="$(echo "${geometry}" | cut -d"+" -f2)"
      y="$(echo "${geometry}" | cut -d"+" -f3)"

      notify "Gif capture starting."

      ffmpeg \
        -f x11grab -video_size "${dim}" -i "${DISPLAY}+${x},${y}" -c:v gif \
        -r "${fps}" \
        -vf "scale='min(${maxRatio},iw)':-1" \
        "${output}" &

      echo $! > "${screenPid}"
      $BAR_UPDATE
    fi
  else
    echo "${RED}Error: capture already in progress.${NC}"
  fi
}

# --------------------------------------------------------------------------
# recording-status
# --------------------------------------------------------------------------

screenRecordingStatus() {
  if [ -e "${screenPid}" ]; then
    echo "recording"
  else
    echo "inactive"
  fi
}

# --------------------------------------------------------------------------
# snap
# --------------------------------------------------------------------------

screenSnap() {
  output="${snapOutputDir}/snap-${datefmt}.png"


  # must be evaluated (eval) to bring the variables to local scope
  eval "$(xdotool getmouselocation --shell)"
  xdotool mousemove --sync "$cursorHideX" "$cursorHideY"

  ffmpeg -f x11grab -video_size "${RES_WIDTH}x${RES_HEIGHT}" -i "${DISPLAY}" -vframes 1 "${output}"

  xdotool mousemove --sync "$X" "$Y"
  notify "Screenshot taken."
}

# --------------------------------------------------------------------------
# stop
# --------------------------------------------------------------------------

screenStop() {
  if [ -e "${screenPid}" ]; then
    pid="$(cat "${screenPid}")"

    kill -15 "$pid"
    rm -f "${screenPid}"

    $BAR_UPDATE
    notify "Capture complete."
  fi
}

# --------------------------------------------------------------------------
# video
# --------------------------------------------------------------------------

screenVideo() {
  if [ -e "${screenPid}" ]; then
    echo "${RED}Error: capture already in progress.${NC}"
  else
    notify "Video capture starting."

    ffmpeg \
      -f x11grab -i "${DISPLAY}" \
      "${captureOutputDir}/video-${datefmt}.mp4" &

    echo $! > "${screenPid}"
    $BAR_UPDATE
  fi
}

# --------------------------------------------------------------------------
# script
# --------------------------------------------------------------------------

case "$1" in
  capture) screenCapture ;;
  crop) screenCrop ;;
  gif) screenGif ;;
  recording-status) screenRecordingStatus ;;
  snap) screenSnap ;;
  stop) screenStop ;;
  video) screenVideo ;;
  *) echo "${RED}USAGE: scene [capture | crop | gif | recording-status | snap | stop | video]${NC}" ;;
esac
