#!/bin/sh
# This script is a dmenu alternative, designed to utilize fzf in 
# a floating st terminal window. Usage is similar to fzf.

tmpDataFileIn="/tmp/shell-menu-in"
tmpDataFileOut="/tmp/shell-menu-out"

c_bg=$SHELLMENU_BG
c_fg=$SHELLMENU_FG
c_match=$SHELLMENU_MATCH
c_sel=$SHELLMENU_SEL
c_arrow=$SHELLMENU_PROMPT

width=$SHELLMENU_WIDTH
height=$SHELLMENU_HEIGHT
x=$SHELLMENU_X
y=$SHELLMENU_Y

if [ ! -f $tmpDataFileIn ]; then
  cat /dev/stdin > $tmpDataFileIn

  color="bg:$SHELLMENU_BG"
  color="$color,fg:$SHELLMENU_FG,prompt:$SHELLMENU_FG,pointer:$SHELLMENU_FG"
  color="$color,hl:$SHELLMENU_MATCH,hl+:$SHELLMENU_MATCH"
  color="$color,fg+:$SHELLMENU_CURRENT,bg+:$SHELLMENU_BG"
  color="$color,info:$SHELLMENU_MATCH"

  st -n shellpopup -G ${width}x${height}+${x}+${y} sh -c \
    "cat $tmpDataFileIn | \
    fzf --reverse --color="$color" \
    $@ > $tmpDataFileOut"

  output=$(cat $tmpDataFileOut)
  rm $tmpDataFileIn $tmpDataFileOut
  echo $output

else
  echo -e "${RED}Another instance of SHELLMENU is already running.${NC}"
  exit 1
fi
