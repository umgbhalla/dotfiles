#!/bin/sh
# opens the default browser with any arguments attached


case "$1" in
  "incognito") exec firejail --profile="${FIREJAIL_PROFILE_DIR}/firefox.profile" firefox -P "$FF_PROFILE" --private-window ;;
  *) exec firejail --profile="${FIREJAIL_PROFILE_DIR}/firefox.profile" firefox -P "$FF_PROFILE" "$@" ;;
esac
