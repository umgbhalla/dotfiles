#!/bin/sh
# given a hex code of form #xxxxxx, returns an rgb color of form rgb(x, x, x)
# e.g. hex2rgb "#abc123" => "rgb(171,193,35)"

[ -f $XDG_CONFIG_HOME/colorrc ] && source $XDG_CONFIG_HOME/colorrc

if [ -z $1 ]; then
  echo -e "${RED}A hex string must be supplied as an argument.${NC}"
  exit 1
fi

hex=${1:1}

if [ ${#hex} != 6 ]; then
  echo -e "${RED}A hex string must be of the format #xxxxxx, where x represents an alphanumeric character within range 0-9a-fA-F.${NC}"
  exit 1
fi

hex=${hex^^} # capitalize hex

a=${hex:0:2}
b=${hex:2:2}
c=${hex:4}

r=$(echo "ibase=16; $a" | bc)
g=$(echo "ibase=16; $b" | bc)
b=$(echo "ibase=16; $c" | bc)

echo "rgb($r,$g,$b)"
