#!/bin/sh

mkdir -p $HOME/Pictures

if [ -z $1 ]; then
  maim "$HOME/Pictures/$(\date +%y-%m-%d_%H:%M:%S).png"
  dunstify -i dialog-information-symbolic.symbolic -t 500 "Screenshot taken."
elif [ $1 == "crop" ]; then
  sleep 0.1
  maim -s "$HOME/Pictures/$(\date +%y-%m-%d_%H:%M:%S).png"
  dunstify -i dialog-information-symbolic.symbolic -t 500 "Screenshot taken."
fi
