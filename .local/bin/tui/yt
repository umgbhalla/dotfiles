#!/bin/sh
# youtube browser

base_url="https://www.youtube.com/results?search_query="

if ! command -v elinks > "/dev/null"; then
  echo "${RED}ERROR: elinks is not installed. Exiting.${NC}"
  exit 1
fi

# read query_raw

# if [ -z "$query_raw" ]; then
#   echo "${RED}USAGE: yt [search query]${NC}"
#   exit 1
# fi

if [ "$#" -lt 1 ]; then
  echo "${RED}USAGE: yt [search query]${NC}"
  exit 1
fi

# syntactic sugar to join all args via the first
# character in IFS, aka the space character
query_raw="$*"

# adapted from Giles' fantastic answer in
# https://unix.stackexchange.com/questions/60653/urlencode-function
urlencode() {
  str="$1"

  while [ -n "$str" ]; do
    tail=${str#?}
    char="${str%$tail}"

    case $char in
      [-._~0-9A-Za-z]) printf %c "$char";;
      *) printf %%%02x "'$char"
    esac

    str="$tail"
  done

  echo
}

query_formatted="$(urlencode "$query_raw")"

url="${base_url}${query_formatted}"

elinks "$url"
