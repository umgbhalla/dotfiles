#!/bin/sh
# Dynamically update all application colors and theming

if [ -z "${1}" ]; then
  echo "${RED}USAGE: SWITCHTHEME [light | dark | time]"
  exit 1
fi

THEME=""
case "${1}" in
  "time")
    hour="$(date +%H)"

    if [ "${hour}" -ge 9 ] && [ "${hour}" -le 20 ]; then
      THEME="light"
    else
      THEME="dark"
    fi
    ;;
  *) THEME="${1}" ;;
esac

CURRENT_THEME_MODE="${THEME}" . $HOME/.profile

while read -r template; do
  eval "$DETEMPLATE $template"
done < "$XDG_CONFIG_HOME/templaterc"

# generate lesskey because less is ridiculous
if command -v lesskey >/dev/null; then
  lesskey "${XDG_CONFIG_HOME}/less/lesskey"
fi

# Xresource colors
# do NOT background; apps may not get updated resources
$XRDB_UPDATE

# update bar
$BAR_UPDATE &

# background
$BACKGROUND
