#!/bin/sh
# builds a given suckless utility using template files

dir="${XDG_CONFIG_HOME}/${1}"

[ -z "${1}" ] && \
  echo "${RED}No suckless utility specified.${NC}" && exit 1
[ ! -d "${dir}" ] && \
  echo "${RED}Invalid suckless utility.${NC}" && exit 1

olddir="$(pwd)"
cd "${dir}"

$DETEMPLATE "template.config.h"
sudo make clean install

cd "${olddir}"
