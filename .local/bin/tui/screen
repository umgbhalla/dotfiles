#!/bin/sh
# manages any form of screen capturing or recording
# in addition to audio capturing and recording.

# --------------------------------------------------------------------------
# environment
# --------------------------------------------------------------------------

# output directories
snapOutputDir=$HOME/Pictures
captureOutputDir=$HOME/Videos
mkdir -p $snapOutputDir
mkdir -p $captureOutputDir

# filename date format
date="$(\date +%y-%m-%d_%H:%M:%S)"

# recording status temporary file path
pidFile=/tmp/ffmpegCapturePid

notifyTime="$HERBE_DURATION"
notifyTimeMs=$(( $(echo $notifyTime | cut -d. -f2) * 100 ))
notify() {
  case $OS in
    $OS_LINUX)
      herbe "$1"
      sleep $notifyTime
      ;;
  esac
}

# manual polybar refresh
refreshBar() {
  touch -m $XDG_CONFIG_HOME/polybar/config
}

# --------------------------------------------------------------------------
# script
# --------------------------------------------------------------------------

case "$1" in

# --------------------------------------------------------------------------
# capture
# --------------------------------------------------------------------------

  capture)
    if [ ! -f $pidFile ]; then
      notify "Screen capture starting."

      case $OS in
        $OS_LINUX)
          ffmpeg \
            -f x11grab -i $DISPLAY \
            -f alsa -i default -c:v libx264 -preset ultrafast -c:a aac \
            "$captureOutputDir/screencapture-$date.mp4" &
          ;;
        *)
          ffmpeg \
            -f x11grab -i $DISPLAY \
            -c:v libx264 -preset ultrafast -c:a aac \
            "$captureOutputDir/screencapture-$date.mp4" &
          ;;
      esac

      echo $! > $pidFile
      refreshBar
    else
      echo -e "${RED}Error: capture already in progress.${NC}"
    fi
    ;;

# --------------------------------------------------------------------------
# crop
# --------------------------------------------------------------------------

  crop)
    output="$snapOutputDir/snap-$date.png"
    geometry=$(slop)

    if [ -z $geometry ]; then
      echo -e "${RED}Error: invalid dimensions.${NC}"
    else
      dim=$(echo $geometry | cut -d+ -f1)
      x="$(echo $geometry | cut -d+ -f2)"
      y="$(echo $geometry | cut -d+ -f3)"

      ffmpeg -f x11grab -video_size $dim -i $DISPLAY+$x,$y -vframes 1 $output
      xclip -selection clip -t image/png $output
      notify "Screenshot taken."
    fi
    ;;

# --------------------------------------------------------------------------
# gif
# --------------------------------------------------------------------------

  gif)
    geometry=$(slop)

    if [ -z $geometry ]; then
      echo -e "${RED}Error: invalid dimensions.${NC}"
    else
      dim=$(echo $geometry | cut -d+ -f1)
      x="$(echo $geometry | cut -d+ -f2)"
      y="$(echo $geometry | cut -d+ -f3)"

      if [ ! -f $pidFile ]; then
        notify "Gif capture starting."

        # largest possible width
        # (incentivize small area recordings!)
        minRatio=800

        ffmpeg \
          -f x11grab -video_size $dim -i $DISPLAY+$x,$y -c:v gif \
          -r 5 \
          -vf "scale='min($minRatio,iw)':-1" \
          "$captureOutputDir/gif-$date.gif" &

          echo $! > $pidFile
          refreshBar
      else
        echo -e "${RED}Error: capture already in progress.${NC}"
      fi
    fi
    ;;

# --------------------------------------------------------------------------
# recording-status
# --------------------------------------------------------------------------

  recording-status)
    if [ -f $pidFile ]; then
      echo 
    else
      echo ""
    fi
    ;;

# --------------------------------------------------------------------------
# snap
# --------------------------------------------------------------------------

  snap)
    output="$snapOutputDir/snap-$date.png"
    ffmpeg -f x11grab -video_size ${RES_WIDTH}x${RES_HEIGHT} -i $DISPLAY -vframes 1 $output
    xclip -selection clip -t image/png $output
    notify "Screenshot taken."
    ;;

# --------------------------------------------------------------------------
# stop
# --------------------------------------------------------------------------

  stop)
    if [ -f $pidFile ]; then
      pid="$(cat $pidFile)"
      kill -15 "$pid"
      rm -f $pidFile

      notify "Capture complete."
      refreshBar
    fi
    ;;

# --------------------------------------------------------------------------
# video
# --------------------------------------------------------------------------

  video)
    if [ ! -f $pidFile ]; then
      notify "Video capture starting."

      ffmpeg \
        -f x11grab -i $DISPLAY \
        "$captureOutputDir/video-$date.mp4" &

        echo $! > $pidFile
        refreshBar
    else
      echo -e "${RED}Error: capture already in progress.${NC}"
    fi
    ;;

# --------------------------------------------------------------------------
# usage
# --------------------------------------------------------------------------

  *)
    echo -e "${RED}Usage: ./screen [capture | crop | gif | recording-status | snap | stop | video]${NC}"
    ;;

  esac
