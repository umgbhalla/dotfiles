#!/bin/sh
# manages any form of screen capturing or recording, 
# in addition to audio capturing and recording.

pidFile=/tmp/ffmpegCapturePid

snapOutputDir=$HOME/Pictures
captureOutputDir=$HOME/Videos

date="$(\date +%y-%m-%d_%H:%M:%S)"

mkdir -p $snapOutputDir
mkdir -p $captureOutputDir

notifyTime=0.5
notifyTimeMs=$(( $(echo $notifyTime | cut -d. -f2) * 100 ))

function notify() {
  dunstify -i camera-photo-symbolic.symbolic -t $notifyTimeMs "$1"
}

case "$1" in

  # capture
  capture)
    if [ ! -f $pidFile ]; then
      notify "Screen capture starting."
      sleep $notifyTime

      ffmpeg \
        -f x11grab -i $DISPLAY \
        -f alsa -i default -c:v libx264 -preset ultrafast -c:a aac \
        "$captureOutputDir/screencapture-$date.mp4" &

        echo $! > $pidFile
        # manual polybar refresh
        touch -m $XDG_CONFIG_HOME/polybar/config
    else
      echo -e "${RED}Error: screen capture already in progress.${NC}"
    fi
    ;;

  # crop
  crop)
    sleep 0.1
    maim -s "$snapOutputDir/snap-$date.png"
    notify "Screenshot taken."
    ;;

  # recording-status
  recording-status)
    if [ -f $pidFile ]; then
      echo 
    else
      echo ""
    fi
    ;;

  # snap
  snap)
    maim "$snapOutputDir/snap-$date.png"
    notify "Screenshot taken."
    ;;

  # stop
  stop)
    if [ -f $pidFile ]; then
      pid="$(cat $pidFile)"
      kill -15 "$pid"
      rm -f $pidFile

      notify "Capture complete."
      # manual polybar refresh
      touch -m $XDG_CONFIG_HOME/polybar/config
    fi
    ;;

  # video
  video)
    if [ ! -f $pidFile ]; then
      notify "Video capture starting."
      sleep $notifyTime

      ffmpeg \
        -f x11grab -i $DISPLAY \
        "$captureOutputDir/video-$date.mp4" &

        echo $! > $pidFile
        # manual polybar refresh
        touch -m $XDG_CONFIG_HOME/polybar/config
    else
      echo -e "${RED}Error: video capture already in progress.${NC}"
    fi
    ;;

  # usage
  *)
    echo -e "${RED}Usage: ./screen [capture | crop | recording-status | snap | stop | video]${NC}"
    ;;

  esac
