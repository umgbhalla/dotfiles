#!/bin/sh
# a script to uniformly alter sound cards, volume, and mixing

# volume up

vol_up() {
  case "$OS" in
    "$OS_FREEBSD") mixer vol "+${1}" ;;
    "$OS_LINUX")
      if command -v "pulseaudio" >/dev/null; then
        pamixer --increase "$1"
      else
        amixer sset Master "${1}+"
      fi
      ;;
  esac
}

# volume down

vol_down() {
  case "$OS" in
    "$OS_FREEBSD") mixer vol "-${1}" ;;
    "$OS_LINUX")
      if command -v "pulseaudio" >/dev/null; then
        pamixer --decrease "$1"
      else
        amixer sset Master "${1}-"
      fi
  esac
}

# volume mute toggle

vol_toggle() {
  tmpVolMute="/tmp/audio_volMute"
  touch $tmpVolMute
  case "$OS" in
    "$OS_FREEBSD")
      volMute=$(cat $tmpVolMute)
      interface="vol"

      # never muted before
      if [ -z $volMute ]; then
        vol=$(mixer $interface | awk '{print $NF}')
        echo "1,$vol" > $tmpVolMute
        mixer $interface 0
      else
        isMuted=$(cut -d, -f1 $tmpVolMute)
        vol=$(cut -d, -f2 $tmpVolMute)
        if [ $isMuted = 1 ]; then
          # unmute
          mixer $interface $vol
          echo "0,0" > $tmpVolMute
        else
          # mute
          vol=$(mixer $interface | awk '{print $NF}')
          echo "1,$vol" > $tmpVolMute
          mixer $interface 0
        fi
      fi
      ;;
    "$OS_LINUX")
      if command -v "pulseaudio" >/dev/null; then
        pamixer --toggle-mute
      else
        status="$(amixer sget Master | awk '/Mono: Playback/ {print $NF}')"
        if [ "$status" = "[on]" ]; then
          amixer sset Master mute
        else
          amixer sset Master unmute
        fi
      fi
      ;;
  esac
}

# input mic mute toggle

mic_toggle() {
  tmpMicMute="/tmp/audio_micMute"
  touch $tmpMicMute
  case $OS in
    $OS_FREEBSD)
      micMute=$(cat $tmpMicMute)
      interface="ogain"

      # never muted before
      if [ -z $micMute ]; then
        vol=$(mixer $interface | awk '{print $NF}')
        echo "1,$vol" > $tmpMicMute
        mixer $interface 0
      else
        isMuted=$(cut -d, -f1 $tmpMicMute)
        vol=$(cut -d, -f2 $tmpMicMute)
        if [ $isMuted = 1 ]; then
          # unmute
          mixer $interface $vol
          echo "0,0" > $tmpMicMute
        else
          # mute
          vol=$(mixer $interface | awk '{print $NF}')
          echo "1,$vol" > $tmpMicMute
          mixer $interface 0
        fi
      fi
      ;;
  esac
}

# control logic

case $1 in
  vol)
    case $2 in
      up)
        if [ -z $3 ]; then echo -e "${RED}USAGE: AUDIO vol up [amount]${NC}";
        else vol_up $3; fi
        ;;
      down)
        if [ -z $3 ]; then echo -e "${RED}USAGE: AUDIO vol down [amount]${NC}";
        else vol_down $3; fi
        ;;
      toggle) vol_toggle ;;
      *) echo -e "${RED}USAGE: AUDIO vol [up | down | toggle]${NC}" ;;
    esac
    ;;
  mic)
    case $2 in
      toggle) mic_toggle ;;
      *) echo -e "${RED}USAGE: AUDIO mic [toggle]${NC}" ;;
    esac
    ;;
  *) echo -e "${RED}USAGE: AUDIO [vol mic]${NC}" ;;
esac

# propogate changes to status bar
$BAR_UPDATE
