#
# bspwm core
#

# reload bspwm
super + shift + r
	bspc wm -r

# quit bspwm
super + shift + Escape
	bspc quit

# node focusing
super {h,j,k,l}
	bspc node -f {west,south,north,east}

# node swaping
super + shift {h,j,k,l}
	bspc node -s {west,south,north,east}

# close node
super + shift + q
	bspc node -k
