
#
# main programs
#

# terminal emulator
super + Return
  $TERM

# launcher
super + space
  dmenu_run

# browser
super + b
  $BROWSER
super + shift + b
  $BROWSER_INCOGNITO

# file explorer
super + y
  $TERM sh -c "$FILE_EXPLORER"

# TODO mail client
#super + m
#	thunderbird

# system profiler
super + p
  $TERM sh -c "$SYSTEM_PROFILER"

# discord (for the meme, of course)
super + u
  discord

# slack (for actual productivity)
super + o
  slack

#
# general scripts
#

super + s
  $XDG_SCRIPT_HOME/bin/run.sh gui
# because I'm dumb and type the wrong binding sometimes
super + shift + s
  $XDG_SCRIPT_HOME/bin/run.sh gui

# emojis
super + e
  $XDG_SCRIPT_HOME/emoji

# 
# networking
#

super + w + i
  $XDG_SCRIPT_HOME/networkmanager_dmenu

#
# audio controls
#

XF86AudioLowerVolume
  pulseaudio-ctl down

XF86AudioRaiseVolume
  pulseaudio-ctl up

XF86AudioMute
  pulseaudio-ctl mute

XF86AudioMicMute
  pulseaudio-ctl mute-input

#
# screen capture
#

Print
  $XDG_SCRIPT_HOME/tui/screenshot

shift + Print
  $XDG_SCRIPT_HOME/tui/screenshot crop

#
# brightness control
#

XF86MonBrightnessUp { , shift }
  {brightnessctl s +5%, $XDG_SCRIPT_HOME/tui/redshift -300}

XF86MonBrightnessDown { , shift }
  {brightnessctl s 5%-, $XDG_SCRIPT_HOME/tui/redshift +300} 

super + shift + braceright
  $XDG_SCRIPT_HOME/tui/redshift -300

super + shift + braceleft
  $XDG_SCRIPT_HOME/tui/redshift +300

super + shift + plus
  $XDG_SCRIPT_HOME/tui/redshift

ctrl + XF86MonBrightnessUp
  $XDG_SCRIPT_HOME/tui/redshift

#
# bspwm core
#

# reload sxhkd, bspwm and other configuration files
super + shift + r
	pkill -USR1 -x sxhkd && \
	bspc wm -r

# quit bspwm
super + shift + Escape
	bspc quit

#
# node management
#

# node focusing
super {h,j,k,l}
	bspc node -f {west,south,north,east}

# node swaping
super + shift {h,j,k,l}
	bspc node -s {west,south,north,east}

# close node
super + shift + q
	bspc node -k

# node layout mode
super + {shift + t,shift + p,shift + space,f}
    bspc node -t '~{tiled,pseudo_tiled,floating,fullscreen}'

#
# workspace management
#

# switch workspace
super {1-9,0}
	bspc desktop -f {I,II,III,IV,V,VI,VII,VIII,IX,X}

# move node to workspace
super + shift + {1-9,0}
	bspc node -d '^{1-9,10}'

# mimic standard floating window cycling
alt + Tab
  bspc node -f next.local

alt + shift + Tab
  bspc node -f prev.local

