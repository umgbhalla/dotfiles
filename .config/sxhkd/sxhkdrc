#
# main programs
#

# terminal emulator
super + Return
  exec $TERM_ARGS

# launcher
super + space
  exec $LAUNCHER

# browser
super + b
  eval $BROWSER_ARGS
super + shift + b
  eval $BROWSER_INCOGNITO

# system profiler
super + p
  exec eval $TERM_ARGS sh -c "$SYSTEM_PROFILER"

# discord (for the meme, of course)
super + u
  exec discord

# slack (for actual productivity)
# super + o
#   slack

# music
super + m
  exec eval $MUSIC_PLAYER_ARGS

#
# general scripts
#

super + s
  exec $XDG_SCRIPT_HOME/run_script
super + e
  exec $XDG_SCRIPT_HOME/emoji

#
# audio controls
#

super + bracketleft
  $AUDIO vol down 5

super + bracketright
  $AUDIO vol up 5

# super + backslash
#   $AUDIO vol toggle

# super + apostrophe
#   $AUDIO mic toggle

#
# screen capture
#

# screenshot

# for ease and alignment with macOS
shift + alt + 3
  $SCREEN snap
shift + alt + 4
  $SCREEN crop

# capture

F10
  $SCREEN capture
F9
  $SCREEN stop
F8
  $SCREEN gif

#
# brightness control
#

super + shift + braceright
  $XDG_SCRIPT_HOME/rshift subtract 300

super + shift + braceleft
  $XDG_SCRIPT_HOME/rshift add 300

super + shift + plus
  $XDG_SCRIPT_HOME/rshift reset

super + ctrl + shift + braceleft
  brightnessctl s 5%-

super + ctrl + shift + braceright
  brightnessctl s +5%

#
# bspwm core
#

# reload bspwm
super + shift + r
  bspc wm -r

# quit bspwm/logout
super + shift + Escape
  bspc quit

#
# node management
#

# node focusing
super {h,j,k,l}
  bspc node -f {west,south,north,east}

# node swaping
super + shift {h,j,k,l}
  bspc node -s {west,south,north,east}

# close node
super + shift + {w,q}
    bspc node -{c,k}

# node layout mode
super + {shift + t,shift + p,shift + space,f}
    bspc node -t '~{tiled,pseudo_tiled,floating,fullscreen}'

#
# workspace management
#

# switch or move workspaces
super + {_,shift + }{1-9,0}
    bspc {desktop -f,node -d} ^{1-9,10}; $BAR_UPDATE

# mimic standard floating window cycling
alt + Tab
  bspc node -f next.local

alt + shift + Tab
  bspc node -f prev.local

