#
# main programs
#

# terminal emulator
super + Return
  eval $TERM_ARGS

# launcher
super + space
  $LAUNCHER

# browser
super + b
  $BROWSER

# system profiler
super + p
  eval $TERM_ARGS sh -c "$SYSTEM_PROFILER"

# discord (for the meme, of course)
super + u
  discord

# slack (for actual productivity)
# super + o
#   slack

# music
super + m
  eval $MUSIC_PLAYER_ARGS

#
# general scripts
#

super + s
  $XDG_SCRIPT_HOME/run_script.sh

# emojis
super + e
  $GUI_DIR/emoji

#
# audio controls
#

super + bracketleft
  $AUDIO vol down 5

super + bracketright
  $AUDIO vol up 5

super + backslash
  $AUDIO vol toggle

super + apostrophe
  $AUDIO mic toggle

#
# screen capture
#

# screenshot

# for ease and alignment with macOS
shift + alt + 3
  $SCREEN snap
shift + alt + 4
  $SCREEN crop

# legacy

Print
  $SCREEN snap
shift + Print
  $SCREEN crop

# capture

F10
  $SCREEN capture
F9
  $SCREEN stop
F8
  $SCREEN gif

#
# brightness control
#

super + shift + braceright
  $XDG_SCRIPT_HOME/tui/redshift subtract 300

super + shift + braceleft
  $XDG_SCRIPT_HOME/tui/redshift add 300

super + shift + plus
  $XDG_SCRIPT_HOME/tui/redshift reset

super + ctrl + shift + braceleft
  brightnessctl s 5%-

super + ctrl + shift + braceright
  brightnessctl s +5%

# legacy

XF86MonBrightnessUp
  brightnessctl s +5%

XF86MonBrightnessDown
  brightnessctl s 5%-

#
# bspwm core
#

# reload bspwm
super + shift + r
  bspc wm -r

# quit bspwm/logout
super + shift + Escape
  bspc quit

#
# node management
#

# node focusing
super {h,j,k,l}
  bspc node -f {west,south,north,east}

# node swaping
super + shift {h,j,k,l}
  bspc node -s {west,south,north,east}

# close node
super + shift + {w,q}
    bspc node -{c,k}

# node layout mode
super + {shift + t,shift + p,shift + space,f}
    bspc node -t '~{tiled,pseudo_tiled,floating,fullscreen}'

#
# workspace management
#

# switch workspace
super {1-9,0}
  bspc desktop -f {I,II,III,IV,V,VI,VII,VIII,IX,X}

# move node to workspace
super + shift + {1-9,0}
  bspc node -d '^{1-9,10}'

# mimic standard floating window cycling
alt + Tab
  bspc node -f next.local

alt + shift + Tab
  bspc node -f prev.local

