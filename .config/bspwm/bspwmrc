#! /bin/sh

# shortcut manager
sxhkd &

# compositor
picom & 

# change desktop cursor to left pointer
xsetroot -cursor_name left_ptr &

# status bar
$HOME/.config/lemonbar/lemonbar.sh | lemonbar -p &

# bspwm defaults
bspc monitor -d I II III IV V VI VII VIII IX X

# background
feh --bg-fill --no-fehbg $HOME/.config/wallpaper.png
