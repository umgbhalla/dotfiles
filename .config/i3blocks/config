
blue=#5170fd
yellow=#ab6a29
red=#993333

#[player]
#command=echo player
#interval=5

[audio]
command=scripts/audio.sh $blue $yellow $red
interval=once
signal=1

[backlight]
command=scripts/light.sh $blue $yellow $red
interval=once
signal=1

#[bluetooth]
#command=echo bluetooth
#interval=30

[memory]
command=scripts/memory.sh $blue $yellow $red
interval=20

[cpu]
command=scripts/cpu.sh $blue $yellow $red
interval=20

[temperature]
command=scripts/temperature.sh $blue $yellow $red
interval=20

[battery]
command=scripts/battery.sh $blue $yellow $red
interval=3

[date]
command=date +"%m⽉%d天 %H:%M"
interval=60

[network]
full_text=
command=swaymsg -q exec wpa_gui

[powermenu]
full_text=
command=swaymsg -q exec "wlogout -l ~/.config/wlogout/layout -C ~/.config/wlogout/style.css"
