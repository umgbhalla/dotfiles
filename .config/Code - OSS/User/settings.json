// VS Code configuration
{
  // ------------------------------------------------------------------------------------------
  // defaults
  // ------------------------------------------------------------------------------------------
  "workbench.startupEditor": "none",
  "window.restoreWindows": "one",
  "editor.tabSize": 2,
  "editor.acceptSuggestionOnEnter": "off",
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,
  "javascript.updateImportsOnFileMove.enabled": "always",
  // prevent update notifications
  "update.mode": "none",
  // ignore extension recommendations from vscode 
  "extensions.ignoreRecommendations": true,
  // zen mode
  "zenMode.centerLayout": false,
  "zenMode.hideLineNumbers": false,
  "zenMode.restore": true,
  "zenMode.hideTabs": false,
  "breadcrumbs.enabled": false,
  "editor.minimap.enabled": true,
  // stop sending crash reports!
  "telemetry.enableCrashReporter": false,
  "telemetry.enableTelemetry": false,
  // source control manager
  "scm.diffDecorations": "gutter",
  // ------------------------------------------------------------------------------------------
  // optimization / reducing footprint
  // ------------------------------------------------------------------------------------------
  // don't parse these folders
  "search.exclude": {
    "**/bower_components": true,
    "**/.DS_Store": true,
    "**/.git/**": true,
    "**/node_modules/**": true,
    "**/.vscode": true
  },
  "files.watcherExclude": {
    "**/bower_components": true,
    "**/.DS_Store": true,
    "**/.git/**": true,
    "**/node_modules/**": true,
    "**/.vscode": true
  },
  "files.exclude": {
    "**/bower_components": true,
    "**/.DS_Store": true,
    "**/.git/**": true,
    "**/node_modules/**": true,
    "**/.vscode": true
  },
  // make terminals render faster
  "terminal.integrated.rendererType": "canvas",
  "terminal.external.linuxExec": "termite",
  "terminal.integrated.showExitAlert": false,
  "window.zoomLevel": 0,
  "window.menuBarVisibility": "toggle",
  "window.customMenuBarAltFocus": false,
  // ------------------------------------------------------------------------------------------
  // color theme
  // ------------------------------------------------------------------------------------------
  "workbench.colorCustomizations": {
    "editor.background": "#2e3440",
    "editor.foreground": "#ccc",
    "sideBar.background": "#262b35",
    "statusBar.background": "#232831",
    "statusBar.foreground": "#ccc",
    "activityBar.background": "#232831",
    "activityBar.foreground": "#aaa",
		"tab.inactiveBackground": "#232831",
		"tab.border": "#2e3440",
		"editorGroupHeader.tabsBackground": "#262b35",
  },
  // ------------------------------------------------------------------------------------------
  // extensions
  // ------------------------------------------------------------------------------------------
  // TO-DO Tree
  "todo-tree.highlights.customHighlight": {
    "TODO": {
      "foreground": "black",
      "background": "yellow"
    },
    "FIXME": {
      "foreground": "black",
      "iconColour": "yellow"
    },
    "TEMP": {
      "foreground": "black",
      "iconColour": "yellow"
    }
  },
  "todo-tree.regex.regexCaseSensitive": false,
  "todo-tree.filtering.ignoreGitSubmodules": true
}

