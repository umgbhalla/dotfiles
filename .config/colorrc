#!/bin/sh
# environment variables pertaining to colors

#
# Xresources-formatted colors
#

export C_BLACK_0="#0d191f"
export C_BLACK_1="#222d32"

export C_RED_0="#ba795c"
export C_RED_1="#ba9a81"

export C_GREEN_0="#626e39"
export C_GREEN_1="#8c9440"

export C_YELLOW_0="#eacc79"
export C_YELLOW_1="#eadfb1"

export C_BLUE_0="#5f819d"
export C_BLUE_1="#81a2be"

export C_MAGENTA_0="#85678f"
export C_MAGENTA_1="#b294bb"

export C_CYAN_0="#44716b"
export C_CYAN_1="#5e8d87"

export C_GRAY_0="#87847d"
export C_GRAY_1="#e6e6e6"

if [ "$CURRENT_THEME_MODE" = "$THEME_LIGHT" ]; then
  export C_BLACK_0="#ccc7af"
  export C_BLACK_1="#b3ae99"

  export C_GRAY_0="#4d4a41"
  export C_GRAY_1="#666357"
fi

#
# terminal colors
#

export BLACK='\033[30m'
export RED='\033[31m'
export GREEN='\033[32m'
export YELLOW='\033[33m'
export BLUE='\033[34m'
export MAGENTA='\033[35m'
export CYAN='\033[36m'
export GRAY='\033[90m'
export WHITE='\033[37m'

export BOLD='\033[1m'
export BLINK='\033[5m'
export NC='\033[0m'
