" vim: filetype=vim

" dark theme
colors dark

" quick command for focusing
command hint_focus hint -;
" Open right click menu on links
bind ;f composite hint_focus; !s xdotool key Menu

" editorcmd (activate with <c-i>)
set editorcmd st nvim

" hint delay
set hintdelay 100

" page zoom
bind <c-K> zoom 0.1 true
bind <c-J> zoom -0.1 true

" disable annoying bookmark pane
bind <c-h> unfocus

" unbind Tridactyl's overriding behavior with C-f
unbind <C-f>

" stop recording history!
set historyresults 0

" hide mode indicator - mostly only use normal anyways
set modeindicator false

" open a new tab in the current container
set tabopencontaineraware true
