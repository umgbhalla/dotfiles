#!/bin/sh

# enable builtin vi command line editor in sh
set -o vi

# aliases
[ -f "${XDG_CONFIG_HOME}/aliasrc" ] && . "${XDG_CONFIG_HOME}/aliasrc"

# terminal ascii
FG=$NC$WHITE
P=$BOLD$CYAN

# scrollback
# HISTFILE="$SH_HISTFILE"
HISTFILE=""
HISTSIZE="1000000"

# prompt
export PS1="$(echo $P)Î»$(echo $NC) "
