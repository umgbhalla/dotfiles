#!/bin/sh

# enable builtin vi command line editor in sh
set -o vi

# aliases
[ -f $XDG_CONFIG_HOME/aliasrc ] && . $XDG_CONFIG_HOME/aliasrc

# terminal ascii
FG=$WHITE
P=$RED
echo -e "${FG}\
 ┌―――――――――――――――――――――――――――――┬―――――――――┐
 ├―――――――――――――――――――――――――――――┘ ${P}▀${FG}  ${P}▀${FG}  ${P}▀${FG} │
 │                                       │
 │                                       │
 │    ${P}/\\,-'''''-,/\\ ${FG}                     │\n\
 │    ${P}\\_)       (_/${FG}                      │\n\
 │    ${P}|           |${FG}                      │\n\
 │    ${P}|           | ${FG}                     │\n\
 │     ${P};         ;     i use bsd btw ~  ${FG} │\n\
 │      ${P}'-_____-' ${FG}                       │\n\
 │                                       │
 └―――――――――――――――――――――――――――――――――――――――┘
${NC}"

# scrollback
HISTSIZE=1000000
set +o nolog

# prompt
export PS1="\W >> "
