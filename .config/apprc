#!/bin/sh
# app-specific environment variables

# general vars

BAR_HEIGHT=28
W_WIDTH=$(( $RES_WIDTH - $(( $W_GAPS + $W_BORDER_WIDTH )) * 2 )) 

if [ $CURRENT_THEME_MODE = $THEME_DARK ]; then
  G_BG=$C_BLACK_0
  G_BG_ALT=$C_BLACK_1
  G_FG=$C_GRAY_1
else
  G_BG=$C_BLACK_0
  G_BG_ALT=$C_BLACK_1
  G_FG=$C_GRAY_1
fi

G_PRIMARY=$C_CYAN_0
G_SECONDARY=$C_MAGENTA_1
G_TERTIARY=$C_YELLOW_0
G_ALERT=$C_RED_0

# theme

# TODO

# bspwm

export BSPWM_TOP_Y="$(( $W_GAPS / 2 ))"
export BSPWM_TOP_PADDING=$(( $BAR_HEIGHT ))
export BSPWM_BORDER_ACTIVE=$G_BG
export BSPWM_BORDER_NORMAL=$BSPWM_BORDER_ACTIVE
export BSPWM_BORDER_FOCUSED=$BSPWM_BORDER_ACTIVE

# discord

export DISCORD_BG="$G_BG$W_ALPHA_HEX"
export DISCORD_FG="$G_FG"
export DISCORD_PRIMARY="$G_BG"

# dunst

export DUNST_WIDTH=400
export DUNST_HEIGHT=70
export DUNST_X="-$(( $W_GAPS * 2 ))"
export DUNST_Y="$DUNST_X"
export DUNST_ICON_SIZE=$(( $DUNST_HEIGHT * 0.8 ))

export DUNST_FONT="Source Code Pro Medium 12"

# higher hex means higher transparency
export DUNST_BG="$G_PRIMARY$W_ALPHA_HEX"
export DUNST_BG_CRITICAL="$G_ALERT$W_ALPHA_HEX"
export DUNST_FG="$G_FG"

# firefox

export FIREFOX_BG_OP=$G_BG
export FIREFOX_BG="rgba($($HEX2FF $G_BG), $W_ALPHA)"
export FIREFOX_BG_ALT="rgba($($HEX2FF $C_GRAY_0), $(printf "%.2f\n" $(( 1 - $W_ALPHA ))))"
export FIREFOX_FG="$C_GRAY_1"
export FIREFOX_FG_ALT="$C_GRAY_0"
export FIREFOX_PRIMARY="$C_CYAN_0"
export FIREFOX_SECONDARY="$C_RED_1"

export FIREFOX_TRANSITION="all 0.2s ease"
export FIREFOX_RADIUS="${W_CORNER_RADIUS}px"

# picom

export PICOM_ALPHA="$(echo $(( $W_ALPHA * 100 )) | sed -e 's/\.//g')"

# polybar

export POLYBAR_X="$W_GAPS"
export POLYBAR_Y="$BSPWM_TOP_Y"
export POLYBAR_WIDTH="100%:-$(( $W_GAPS * 2 ))"
export POLYBAR_HEIGHT=$BAR_HEIGHT

export POLYBAR_BG="#00${G_BG:1}"
export POLYBAR_FG="$G_FG"
export POLYBAR_PRIMARY="$G_BG"
export POLYBAR_SECONDARY="$G_SECONDARY"
export POLYBAR_TERTIARY="$G_TERTIARY"
export POLYBAR_ALERT="$G_ALERT"

# shellmenu

export SHELLMENU_WIDTH="$W_WIDTH"
export SHELLMENU_HEIGHT=300
export SHELLMENU_X=$W_GAPS
export SHELLMENU_Y=$BSPWM_TOP_Y

export SHELLMENU_BG="$C_CYAN_0"
export SHELLMENU_FG="$G_FG"
export SHELLMENU_MATCH="$C_BLACK_0"
export SHELLMENU_SEL="$C_RED_1"
export SHELLMENU_PROMPT="$C_BLACK_0"

# spicetify

export SPICETIFY_BG="${G_BG:1}"
export SPICETIFY_BG_ALT="${G_BG_ALT:1}"
export SPICETIFY_FG="${G_FG:1}"
export SPICETIFY_PRIMARY="${G_PRIMARY:1}"
export SPICETIFY_SECONDARY="${G_SECONDARY:1}"
export SPICETIFY_TERTIARY="${G_TERTIARY:1}"
export SPICETIFY_ALERT="${G_ALERT:1}"

# st

export ST_FONT="Source Code Pro Medium:pixelsize=15:antialias=true:autohint=true"
export ST_PADDING="$(( $W_GAPS * 1.5 ))"

# zathura

export ZATHURA_BG="$($HEX2RGB $G_BG | sed -e s/b/ba/ -e s/\)/,$W_ALPHA\)/)"
export ZATHURA_BG_ALT="$($HEX2RGB $G_BG_ALT | sed -e s/b/ba/ -e s/\)/,$W_ALPHA\)/)"
export ZATHURA_FG="$G_FG"
export ZATHURA_PRIMARY="$G_PRIMARY"
