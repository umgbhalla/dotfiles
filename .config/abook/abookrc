# vim: filetype=sh
set preserve_fields = all

field birthday = Birthday, date
field work = Workplace, string
field maiden_name = "Maiden Name", string

field fb = Facebook, string
field insta = Instagram, string
field twitter = Twitter, string
field discord = Discord, string
field wechat = Wechat, string
field mastodon = Mastodon, string

view CONTACT = name, nick, email, mobile, notes
view WORK = work, workphone
view ADDRESS = address, address2, city, state, zip, country
view OTHER = birthday, maiden_name, phone, fax, anniversary
view SOCIALS = url, fb, insta, twitter, discord, wechat, mastodon
