# package manager
case "$OS" in
  "$OS_LINUX")
    alias p="sudo pacman"
    alias y="paru"
    ;;
  "$OS_FREEBSD")
    alias p="sudo pkg"
    alias y="sudo portsnap"
    ;;
  "$OS_OPENBSD")
    # refrain from using OpenBSD's package tools because it's better
    # to build from source with as few packages as possible
    p() {
      echo -e "${RED}Stop installing packages. It's bad for you.${NC}"
    }
    y() {
      p $@
    }
    ;;
esac

