#!/bin/sh
# collection of commonly used shell aliases and definitions

# ----------------------------------------------------------------
# defaults
# ----------------------------------------------------------------

alias \
  cp="cp -v" \
  mv="mv -v" \
  rm="rm -v" \
  md="mkdir -pv" \
  grep="grep --color=auto"

case "$OS" in
  "$OS_LINUX")
    alias ls="ls --color=auto --group-directories-first"
    alias sed="sed --posix"
    alias bc="bc -w -q"
    ;;
  "$OS_OPENBSD")
    alias ls="ls -F"
    alias md="mkdir -p"
    unalias grep
    ;;
  *)
    alias ls="ls -GF"
    ;;
esac

cd() {
  builtin cd "$@" && ls
}

# ----------------------------------------------------------------
# system session
# ----------------------------------------------------------------

case "$OS" in
  "$OS_LINUX")
    alias \
      reboot="sudo reboot" \
      shutdown="sudo poweroff" \
      suspend="sudo systemctl suspend" \
      hibernate="sudo systemctl hibernate"
    ;;
  "$OS_FREEBSD")
    alias \
      reboot="sudo reboot" \
      shutdown="sudo poweroff" \
      suspend="sudo acpiconf -s 3" \
      hibernate="sudo acpiconf -s 5"
    ;;
  "$OS_OPENBSD")
    alias \
      reboot="doas reboot" \
      shutdown="doas shutdown -p now" \
      suspend="echo -e \"${RED}Suspend yourself.${NC}\"" \
      hibernate="echo -e \"${RED}What do you think I am? A bear?${NC}\""
    ;;
esac

