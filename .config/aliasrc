# repo browser
function rp() {
  mkdir -p $XDG_REPO_HOME
  repo=$(ls $XDG_REPO_HOME | fzf)
  cd $XDG_REPO_HOME/$repo
}

rangerDir=$XDG_CACHE_HOME/ranger_last_dir
configEditList="find -L $XDG_CONFIG_HOME $XDG_SCRIPT_HOME -type f | fzf"

alias \
  r='ranger --choosedir=$rangerDir; LASTDIR=`cat $rangerDir`; cd $LASTDIR' \
  c="$configEditList | xargs -r $EDITOR"

if [ $OS = $OS_MACOS ]; then
  alias c="$configEditList | xargs -I F $EDITOR \"F\""
fi

# bookmarks
function b() {
  touch $BOOKMARK_CONFIG
  bpath=$(cat $BOOKMARK_CONFIG | fzf | cut -d',' -f2)
  bpath=$(eval "echo $bpath")

  if [ ! -z $bpath ] && ! cd $bpath; then
    echo -e "${RED}Error: invalid bookmark.${NC}"
    echo -e "${RED}Add new bookmarks to $BOOKMARK_CONFIG with the format 'identifier, path'${NC}"
    sleep 1s
    $EDITOR $BOOKMARK_CONFIG
  fi
}

