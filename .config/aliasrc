# suckless building
function sbuild() {
  dir=$XDG_CONFIG_HOME/$1

  [ -z $1 ] && \
    echo -e "${RED}No suckless utility specified.${NC}" && return
  [ ! -d $dir ] && \
    echo -e "${RED}Invalid suckless utility.${NC}" && return

  olddir=$(pwd)
  cd $dir
  $DETEMPLATE template.config.h && sudo make clean install
  cd $olddir
}

# ----------------------------------------------------------------
# version control
# ----------------------------------------------------------------

# git wrapper
#
# git clone URL --branch BRANCH
# to merge the last n remote commits in branch b:
# git rebase -i origin/b~n b
# git push origin +b
function g() {
  case "$1" in
    clone)
      # if repo is not renamed
      if [ -z "$3" ]; then 
        git clone --recursive "$2" && cd "$(basename "$2" .git)"
      else
        git clone --recursive "${@:2}" && cd "$3"
      fi
      ;;
    *) git $@;
  esac
}

