#!/bin/sh
# collection of commonly used shell alias definitions

[ -f $XDG_CONFIG_HOME/colorrc ] && source $XDG_CONFIG_HOME/colorrc

# ----------------------------------------------------------------
# defaults
# ----------------------------------------------------------------

alias \
    ls="ls --color=auto --group-directories-first" \
    cp="cp -v" \
    mv="mv -v" \
    rm="rm -v" \
    md="mkdir -pv" \
    grep="grep --color=auto"
    
function cd() { builtin cd "$@" && ls }

# ----------------------------------------------------------------
# session
# ----------------------------------------------------------------

alias \
  reboot="sudo reboot" \
  shutdown="sudo shutdown -h now"

# ----------------------------------------------------------------
# programs
# ----------------------------------------------------------------

# core
alias \
  p="sudo pacman" \
  y="yay" \
  g="git" \
  system="sudo systemctl" \
  vim="nvim" \
  wifi="networkmanager_dmenu" \
  pk="ps aux | dmenu -i -l 20 | awk '{print $2}' | xargs kill -9 > /dev/null" \
  zr="source $XDG_CONFIG_HOME/zsh/.zshrc" \
  date="cal -3 && date && echo"

function rp() {
  repoPath="$HOME/Repos"
  repo=$(ls -d $repoPath/* | sed 's/^\/.*\///' | dmenu -i -l 20)
  cd $repoPath/$repo
}

# navigation
alias \
  r="ranger" \
  rc='ranger --choosedir=$XDG_CACHE_HOME/ranger_dir; LASTDIR=`cat $XDG_CACHE_HOME/ranger_dir`; cd "$LASTDIR"' \
  c="find -L $XDG_CONFIG_HOME -type f | fzf | xargs -r $EDITOR"

# ----------------------------------------------------------------
# media
# ----------------------------------------------------------------

# mounting
mntpt="/mnt/usb"
function mnt() {
  drive="$(sudo fdisk -l | grep '^Disk.*sectors$' | dmenu -i -l 20 | awk '{print $2}')"
  drive=${drive:0:-1}
  sudo mkdir -p $mntpt
  sudo ntfs-3g "$drive" "$mntpt"
  cd "$mntpt"
}
function umnt() { cd $HOME && sync && sudo umount $mntpt }

function dlLink() {
  youtube-dl --add-metadata -i $@
  unsetopt noglob
}

# davinci resolve codec converter
function dav() { ffmpeg -i $1 -c:v dnxhd -profile:v 1 -pix_fmt yuv422p -c:a pcm_s16le -f mov $2 }

alias \
  mt="mnt" \
  umt="umnt" \
  ytmp4="setopt noglob && dlLink -f 22" \
  ytmp3="setopt noglob && dlLink -x --audio-format mp3" \
  feh="feh --scake-down --auto-zoom"

# ----------------------------------------------------------------
# miscellaneous
# ----------------------------------------------------------------

# firebase
alias firebase="`npm config get prefix`/bin/firebase"

