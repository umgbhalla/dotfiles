if [ "${OS}" = "${OS_FREEBSD}" ]; then
  getusbdevs() {
    echo "$(sudo usbconfig | grep -o "^.*:" | tr -d ":")"
  }

  usboff() {
    getusbdevs | xargs -I {} sudo usbconfig -d {} power_off
    echo "usbs off"
  }

  usbon(){
    getusbdevs | xargs -I {} sudo usbconfig -d {} power_on
    echo "usbs on"
  }
fi

# archive extraction
e() {
  if [ -z "$1" ]; then
    echo "${RED}USAGE: e [archive]${NC}"
    return
  fi
  if [ -f "$1" ]; then
    # dir="$(echo "$1" | cut -d'.' -f1)"
    # mkdir -p "$dir"
    case "$1" in
      *.asar)      asar e "$1" "$dir" ;;
      *.tar.bz2)   tar xvjf "$1"    ;;
      *.tar.gz)    tar -xvf "$1"    ;;
      *.tar.xz)    tar xvJf "$1"    ;;
      *.bz2)       bunzip2 "$1"     ;;
      *.rar)       unrar x "$1"     ;;
      *.gz)        gunzip "$1"      ;;
      *.tar)       tar xvf "$1"     ;;
      *.tbz2)      tar xvjf "$1"    ;;
      *.tgz)       tar xvzf "$1"    ;;
      *.zip)       unzip "$1" -d "$dir"      ;;
      *.Z)         uncompress "$1"  ;;
      *.7z)        7z x "$1"        ;;
      *.xz)        unxz "$1"        ;;
      *.exe)       cabextract "$1"  ;;
      *)           echo "${RED}${1}: unrecognized file compression${NC}" ;;
    esac
    # cd "$dir"
  else
    echo "${RED}${1} is not a valid file${NC}"
  fi
}

