pl() {
  # devour mpv
  if [ -z "$1" ]; then
    echo "${RED}USAGE: pl [options] [playlist]${NC}"
  else
    case "$1" in
      # audio only
      *"sc"*|*"soundcloud"*) mpv "$@" ;;
      # YT video
      *) devour mpv "$@" ;;
    esac
  fi
}
alias hdmipl="pl --audio-device=alsa/plughw:0,3"

# process kill
pk() {
  proc="$(ps aux | \
    sed 1d | \
    tr -s " " | \
    cut -d " " -f1-2,11- | \
    fzf)"

  if [ -n "${proc}" ]; then
    pid="$(echo "${proc}" | cut -d " " -f 2)"
    kill -9 "$pid"
  else
    echo "${RED}No process specified.${NC}"
  fi
}

