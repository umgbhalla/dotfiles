  alias p="sudo pacman"
  alias y="unset GIT_CONFIG && yay --norebuild --noredownload"
elif [ $OS = $OS_FREEBSD ]; then
  alias p="sudo pkg"
  alias y="sudo portsnap"
fi

# core
alias \
  date="cal -3 && date && echo" \
  m="rm -f $XDG_CONFIG_HOME/cmus/cache && cmus $HOME/Music" \
  msr="$MUSIC_PLAYER_ARGS" \
  n="newsboat -u $NEWSBOAT_CONFIG/urls -C $NEWSBOAT_CONFIG/config" \
  pdf="pdflatex" \
  pk="ps aux | fzf | awk '{print $2}' | tr -d '\n' | xargs kill -9" \
  s="$XDG_SCRIPT_HOME/run_script.sh" \
  sbuild="$SBUILD" \
  ss="sc-im" \
  surf="surf -g" \
  system="sudo systemctl" \
  vim="nvim" \
  wi="nmtui" \
  yarn="HOME=$YARN_RC_DIR PREFIX=$YARN_GLOBAL_DIR yarn" \
  zr="clear && . $ENV"

