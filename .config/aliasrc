clearcache() {
  case "$OS" in
    "$OS_LINUX")
      # clear repository caches
      # if you want to clear the WHOLE cache, try -Scc (unrecommended)
      sudo pacman -Sc
      paru -Sc

      sudo journalctl --rotate
      sudo journalctl --vacuum-time=1d

      # clear any files in trash
      rm -r ${XDG_DATA_HOME}/Trash/* 2> "$NULL"
      rm -r ${XDG_DATA_HOME}/vifm/Trash/* 2> "$NULL"
      ;;
  esac
}

# merge pdfs
pdfmerge() {
  out="$1"
  shift
  in="$@"
  gs -dBATCH -dNOPAUSE -q -sDEVICE=pdfwrite -sOutputFile="$out" $in
}

