#!/bin/sh
# collection of commonly used shell alias definitions
source $HOME/.config/colorrc

# defaults
alias \
    ls="ls --color=auto --group-directories-first" \
    cp="cp -v" \
    mv="mv -v" \
    rm="rm -v" \
    mkdir="mkdir -pv"

# ignore vim
function vim() { echo -e "${LB}the local wizard says that vim does not exist in this universe.\nTry using nvim instead.${NC}" }
