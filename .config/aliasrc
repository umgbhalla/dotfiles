# mounting
mntpt="/mnt/usb"
function mnt() {
  drive="$(sudo fdisk -l | grep '^Disk.*sectors$' | dmenu -i -l 20 | awk '{print $2}')"
  drive=${drive:0:-1}
  sudo mkdir -p $mntpt
  sudo ntfs-3g "$drive" "$mntpt"
  cd "$mntpt"
}
function umnt() { cd $HOME && sync && sudo umount $mntpt }

function dlLink() {
  youtube-dl --add-metadata -i $@
  unsetopt noglob
}

# davinci resolve codec converter
function dav() { ffmpeg -i $1 -c:v dnxhd -profile:v 1 -pix_fmt yuv422p -c:a pcm_s16le -f mov $2 }

alias \
  mt="mnt" \
  umt="umnt" \
  ytmp4="setopt noglob && dlLink -f 22" \
  ytmp3="setopt noglob && dlLink -x --audio-format mp3" \
  feh="feh --scale-down --auto-zoom"

# archive extraction
extract () {
  if [ -f $1 ] ; then
    case $1 in
      *.tar.bz2)   tar xvjf $1    ;;
      *.tar.gz)    tar -xvf $1    ;;
      *.tar.xz)    tar xvJf $1    ;;
      *.bz2)       bunzip2 $1     ;;
      *.rar)       unrar x $1     ;;
      *.gz)        gunzip $1      ;;
      *.tar)       tar xvf $1     ;;
      *.tbz2)      tar xvjf $1    ;;
      *.tgz)       tar xvzf $1    ;;
      *.zip)       unzip $1       ;;
      *.Z)         uncompress $1  ;;
      *.7z)        7z x $1        ;;
      *.xz)        unxz $1        ;;
      *.exe)       cabextract $1  ;;
      *)           echo "\`$1': unrecognized file compression" ;;
    esac
  else
    echo "\`$1' is not a valid file"
  fi
}
alias e="extract"

