alias clear-cache="sync; echo 1 | sudo tee /proc/sys/vm/drop_caches"
clear-cached-files() {
  rm -rf /home/$USER/Downloads/*
  rm -rf /home/$USER/Pictures/*
}

# list all open windows
alias windows="wmctrl -l"

# xinput natural scrolling
alias nat="xinput set-prop \"System mouse\" \"libinput Natural Scrolling Enabled\" 1"
