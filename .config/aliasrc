# latex compilation
lat() {
  if [ -z "$1" ]; then
    echo "${RED}ERROR: file not supplied${NC}"
    exit 1
  fi

  file="$(echo "$1" | cut -d '.' -f 1)"

  pdflatex "$file"
  bibtex "$file"
  pdflatex "$file"
  pdflatex "$file"
}

