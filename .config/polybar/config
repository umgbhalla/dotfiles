; polybar configuration

[colors]
background = ${env:COLOR_BG:#f02e3440}
background-alt = ${env:COLOR_TERTIARY:#5d62ac}
foreground = ${env:COLOR_FG:#eceff4}
primary = ${env:COLOR_PRIMARY:#febdf7}
secondary = ${env:COLOR_SECONDARY:#81a1c1}
alert = ${env:COLOR_ALERT:#bf616a}
transparent = #00000000

[global/wm]
margin-top = 0
margin-bottom = 0

[bar/main]
width = 100%
height = ${env:WM_BAR_HEIGHT:30}
override-redirect = true
; always display below fullscreen windows
wm-restack = "bspwm"

background = ${colors.background}
foreground = ${colors.foreground}

radius = ${env:WINDOW_BORDER_RADIUS:8}
border-size = ${env:WM_GAPS:16}
border-color = ${colors.transparent}

font-0 = Source Code Pro Medium:pixelsize=12;10:antialias=true:autohint=true;2
font-1 = FontAwesome:pixelsize=12;2
font-2 = Source Code Pro Medium:bold:pixelsize=12:antialias=true:autohint=true;2
font-3 = WenQuanYi Zen Hei Mono:pixelsize=12;1

modules-left = bspwm
modules-center = title 
; modules-center = mpris title 
modules-right = wlan eth pulseaudio battery date

cursor-click = pointer

[module/bspwm]
type = internal/bspwm

label-focused = %icon%
label-focused-background = ${colors.primary}
label-focused-foreground = ${colors.background}
label-focused-padding = 2

label-occupied = %icon%
label-occupied-background = ${colors.background-alt}
label-occupied-padding = 2

label-urgent = %icon%
label-urgent-background = ${colors.alert}
label-urgent-padding = 2

label-empty = %icon%
label-empty-background = ${colors.background}
label-empty-padding = 2

ws-icon-0 = "I;´äí"
ws-icon-1 = "II;´őÉ"
ws-icon-2 = "III;´äŤ"
ws-icon-3 = "IV;´üÁ"
ws-icon-4 = "V;´ç╝"
ws-icon-5 = "VI;ňůş"
ws-icon-6 = "VII;ńŞâ"
ws-icon-7 = "VIII;ňůź"
ws-icon-8 = "IX;ń╣Ł"
ws-icon-9 = "X;´Çü"
ws-icon-default = "´üĘ"

[module/mpris]
type = custom/script
format-font = 1
exec = $XDG_CONFIG_HOME/polybar/mpris.py -f '{:artist:t20:{artist}:}{:artist: - :}{:t60:{title}:}'
tail = true

format-background = ${colors.background}
format-foreground = ${colors.primary}
format-padding = 2

[module/title]
type = internal/xwindow
label-maxlen = 60
format-font = 3
format-foreground = ${colors.primary}

[module/wlan]
type = internal/network
interface = ${env:WIFI_INTERFACE:wlan0}
interval = 3.0

format-connected-background = ${colors.secondary}
format-connected-foreground = ${colors.foreground}
format-connected-padding = 2
label-connected = ´çź %essid%

format-disconnected-background = ${colors.background}
format-disconnected-foreground = ${colors.primary}
format-disconnected-padding = 2
label-disconnected = 

[module/eth]
type = internal/network
interface = ${env:ETH_INTERFACE:wlan0}
interval = 3.0

format-connected-background = ${colors.secondary}
format-connected-foreground = ${colors.foreground}
format-connected-padding = 2
label-connected = ´Çĺ %local_ip%

format-disconnected-background = ${colors.background}
format-disconnected =

[module/pulseaudio]
type = internal/pulseaudio

format-volume = <label-volume>
label-volume = ´ÇĘ %percentage%%
label-volume-background = ${colors.background}
label-volume-padding = 2

label-muted = ´ÇĘ --%
label-muted-foreground = ${colors.primary}
label-muted-background = ${colors.background}
label-muted-padding = 2

[module/battery]
type = internal/battery
battery = BAT0
adapter = ADP1
full-at = 98

format-full = ´ëÇ <label-full>
format-full-background = ${colors.primary}
format-full-foreground = ${colors.background}
format-full-padding = 2

format-charging = ´âž <label-charging>
format-charging-background = ${colors.primary}
format-charging-foreground = ${colors.background}
format-charging-padding = 2

format-discharging = ´ëä <label-discharging>
format-discharging-background = ${colors.secondary}
format-discharging-foreground = ${colors.background}
format-discharging-padding = 2

[module/date]
type = internal/date
interval = 5

date = %a %b %d
time = %H:%M
label = ´ä│ %date% %time%

format-background = ${colors.background-alt}
format-foreground = ${colors.foreground}
format-padding = 2

