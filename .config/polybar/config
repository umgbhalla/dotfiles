; polybar configuration

[colors]
background = #2e3440
background-alt = #4c566a
foreground = #eceff4
primary = #ebcb8b
secondary = #81a1c1
tertiary = #a3be8c
alert = #bf616a
transparent = #00000000

[global/wm]
margin-top = 0
margin-bottom = 0

[bar/main]
width = 100%
height = 32
override-redirect = true

background = ${colors.background}
foreground = ${colors.foreground}

border-size = 0
border-color = ${colors.transparent}

font-0 = LiberationMono:pixelsize=12:antialias=true:autohint=true;1
font-1 = FontAwesome:style=Regular
font-2 = LiberationMono:bold:pixelsize=12:antialias=true:autohint=true;1

modules-left = bspwm
modules-center = mpris
modules-right = wlan eth pulseaudio battery date

cursor-click = pointer

[module/bspwm]
type = internal/bspwm

label-focused = %index%
label-focused-background = ${colors.primary}
label-focused-foreground = ${colors.background}
label-focused-padding = 2

label-occupied = %index%
label-occupied-background = ${colors.background-alt}
label-occupied-padding = 2

label-urgent = %index%!
label-urgent-background = ${colors.alert}
label-urgent-padding = 2

label-empty = %index%
label-empty-background = ${colors.background}
label-empty-padding = 2

[module/mpris]
type = custom/script
format-font = 3
exec = $XDG_CONFIG_HOME/polybar/mpris.py -f '%{A1:$XDG_CONFIG_HOME/polybar/mpris.py previous:}%{A}  %{A1:$XDG_CONFIG_HOME/polybar/mpris.py play-pause:}{icon-reversed}%{A}  %{A1:$XDG_CONFIG_HOME/polybar/mpris.py next:}%{A}  {:artist:t10:{artist}:}{:artist: - :}{:t40:{title}:}' --icon-stopped '' --icon-none '' --icon-playing '' --icon-paused ''
tail = true

format-background = ${colors.background}
format-foreground = ${colors.secondary}
format-padding = 2

[module/wlan]
type = internal/network
interface = wlp1s0
interval = 3.0

format-connected-background = ${colors.background}
format-connected-foreground = ${colors.tertiary}
format-connected-padding = 2
label-connected = %essid%

format-disconnected-background = ${colors.background}
format-disconnected-foreground = ${colors.primary}
format-disconnected-padding = 2
label-disconnected = 

[module/eth]
type = internal/network
interface = enp0s31f6
interval = 3.0

format-connected-background = ${colors.background}
format-connected-foreground = ${colors.tertiary}
format-connected-padding = 2
label-connected = %local_ip%

format-disconnected-background = ${colors.background}
format-disconnected =

[module/pulseaudio]
type = internal/pulseaudio

format-volume = <label-volume>
label-volume = %percentage%%
label-volume-background = ${colors.background}
label-volume-padding = 2

label-muted = --%
label-muted-foreground = ${colors.primary}
label-muted-background = ${colors.background}
label-muted-padding = 2

[module/battery]
type = internal/battery
battery = BAT0
adapter = ADP1
full-at = 98

format-full = <label-full>
format-full-background = ${colors.tertiary}
format-full-foreground = ${colors.background}
format-full-padding = 2

format-charging = <label-charging>
format-charging-background = ${colors.tertiary}
format-charging-foreground = ${colors.background}
format-charging-padding = 2

format-discharging = <label-discharging>
format-discharging-background = ${colors.primary}
format-discharging-foreground = ${colors.background}
format-discharging-padding = 2

[module/date]
type = internal/date
interval = 5

date = %m/%d
time = %H:%M
label = %date% %time%

format-background = ${colors.secondary}
format-foreground = ${colors.background}
format-padding = 2

