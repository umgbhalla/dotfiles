; polybar configuration

[colors]
background = ${env:POLYBAR_BG}
foreground = ${env:POLYBAR_FG}
primary = ${env:POLYBAR_PRIMARY}
secondary = ${env:POLYBAR_SECONDARY}
tertiary = ${env:POLYBAR_TERTIARY}
alert = ${env:POLYBAR_ALERT}
transparent = #00000000

[global/wm]
margin-top = 0
margin-bottom = 0

[bar/main]
width = ${env:POLYBAR_WIDTH}
height = ${env:POLYBAR_HEIGHT}
offset-x = ${env:POLYBAR_X}
offset-y = ${env:POLYBAR_Y}

; always display below fullscreen windows
override-redirect = true
wm-restack = ${env:WM}

background = ${colors.background}
foreground = ${colors.foreground}

font-0 = Source Code Pro Medium:pixelsize=12;10:antialias=true:autohint=true;3
font-1 = FontAwesome:pixelsize=14;3
font-2 = Source Code Pro Medium:bold:pixelsize=12:antialias=true:autohint=true;3
font-3 = WenQuanYi Zen Hei Mono:pixelsize=14;3

modules-left = bspwm
modules-center = title
modules-right = capture wlan eth pulseaudio battery date

cursor-click = pointer

tray-position = right

[module/bspwm]
type = internal/bspwm

label-focused = %icon%
label-focused-foreground = ${colors.primary}
label-focused-padding = 2

label-occupied = %icon%
label-occupied-foreground = ${colors.secondary}
label-occupied-padding = 2

label-urgent = %icon%
label-urgent-foreground = ${colors.alert}
label-urgent-padding = 2

label-empty = %icon%
label-empty-padding = 2

ws-icon-0 = "I;"
ws-icon-1 = "II;"
ws-icon-2 = "III;"
ws-icon-3 = "IV;"
ws-icon-4 = "V;"
ws-icon-5 = "VI;"
ws-icon-6 = "VII;"
ws-icon-7 = "VIII;"
ws-icon-8 = "IX;"
ws-icon-9 = "X;"
ws-icon-default = ""

[module/title]
type = internal/xwindow
label-maxlen = 60
format-font = 3

[module/capture]
type = custom/script
exec = $SCREEN recording-status

click-left = $SCREEN stop

format-foreground = ${colors.alert}
format-padding = 2

; since script manually updates bar
tail = true

[module/wlan]
type = internal/network
interface = ${env:WIFI_INTERFACE:wlan0}
interval = 3.0

format-connected-foreground = ${colors.foreground}
format-connected-padding = 2
label-connected =  %essid%

format-disconnected-background = ${colors.background}
label-disconnected = 

[module/eth]
type = internal/network
interface = ${env:ETH_INTERFACE:wlan0}
interval = 3.0

format-connected-foreground = ${colors.foreground}
format-connected-padding = 2
label-connected =  %local_ip%

format-disconnected-background = ${colors.background}
format-disconnected =

[module/pulseaudio]
type = internal/pulseaudio

format-volume = <label-volume>
label-volume =  %percentage%%
label-volume-padding = 2

label-muted =  --%
label-muted-foreground = ${colors.secondary}
label-muted-padding = 2

[module/battery]
type = internal/battery
battery = BAT0
adapter = ADP1
full-at = 98

format-full =  <label-full>
format-full-foreground = ${colors.foreground}
format-full-padding = 2

format-charging =  <label-charging>
format-charging-foreground = ${colors.foreground}
format-charging-padding = 2

format-discharging =  <label-discharging>
format-discharging-foreground = ${colors.primary}
format-discharging-padding = 2

[module/date]
type = internal/date
interval = 5

date = %a %b %d
time = %H:%M
label =  %date% %time%

format-foreground = ${colors.foreground}
format-padding = 2
