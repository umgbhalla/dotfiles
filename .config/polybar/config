; polybar configuration

[colors]
background = ${env:COLOR_BG:#f02e3440}
background-alt = ${env:COLOR_TERTIARY:#5d62ac}
foreground = ${env:COLOR_FG:#eceff4}
primary = ${env:COLOR_PRIMARY:#febdf7}
secondary = ${env:COLOR_SECONDARY:#81a1c1}
alert = ${env:COLOR_ALERT:#bf616a}
transparent = #00000000

[global/wm]
margin-top = 0
margin-bottom = 0

[bar/main]
width = 100%
height = ${env:WM_BAR_HEIGHT:30}
override-redirect = true
wm-restack = bspwm ; always display below fullscreen windows

background = ${colors.background}
foreground = ${colors.foreground}

radius = ${env:WINDOW_BORDER_RADIUS:8}
border-size = ${env:WM_GAPS:16}
border-color = ${colors.transparent}

font-0 = Source Code Pro Medium:pixelsize=12:antialias=true:autohint=true;1
font-1 = FontAwesome:style=Regular
font-2 = Source Code Pro Medium:bold:pixelsize=12:antialias=true:autohint=true;1

modules-left = bspwm
modules-center = title mpris
modules-right = wlan eth pulseaudio battery date

cursor-click = pointer

[module/bspwm]
type = internal/bspwm

label-focused = %index%
label-focused-background = ${colors.primary}
label-focused-foreground = ${colors.background}
label-focused-padding = 2

label-occupied = %index%
label-occupied-background = ${colors.background-alt}
label-occupied-padding = 2

label-urgent = %index%!
label-urgent-background = ${colors.alert}
label-urgent-padding = 2

label-empty = %index%
label-empty-background = ${colors.background}
label-empty-padding = 2

[module/mpris]
type = custom/script
format-font = 1
exec = $XDG_CONFIG_HOME/polybar/mpris.py -f '{:artist:t20:{artist}:}{:artist: - :}{:t70:{title}:}'
tail = true

format-background = ${colors.background}
format-foreground = ${colors.primary}
format-padding = 2

[module/title]
type = internal/xwindow

[module/wlan]
type = internal/network
interface = ${env:WIFI_INTERFACE:wlan0}
interval = 3.0

format-connected-background = ${colors.background}
format-connected-foreground = ${colors.secondary}
format-connected-padding = 2
label-connected = %essid%

format-disconnected-background = ${colors.background}
format-disconnected-foreground = ${colors.primary}
format-disconnected-padding = 2
label-disconnected = 

[module/eth]
type = internal/network
interface = ${env:ETH_INTERFACE:wlan0}
interval = 3.0

format-connected-background = ${colors.background}
format-connected-foreground = ${colors.background-alt}
format-connected-padding = 2
label-connected = %local_ip%

format-disconnected-background = ${colors.background}
format-disconnected =

[module/pulseaudio]
type = internal/pulseaudio

format-volume = <label-volume>
label-volume = %percentage%%
label-volume-background = ${colors.background}
label-volume-padding = 2

label-muted = --%
label-muted-foreground = ${colors.primary}
label-muted-background = ${colors.background}
label-muted-padding = 2

[module/battery]
type = internal/battery
battery = BAT0
adapter = ADP1
full-at = 98

format-full = <label-full>
format-full-background = ${colors.primary}
format-full-foreground = ${colors.background}
format-full-padding = 2

format-charging = <label-charging>
format-charging-background = ${colors.primary}
format-charging-foreground = ${colors.background}
format-charging-padding = 2

format-discharging = <label-discharging>
format-discharging-background = ${colors.secondary}
format-discharging-foreground = ${colors.background}
format-discharging-padding = 2

[module/date]
type = internal/date
interval = 5

date = %a %b %d
time = %H:%M
label = %date% %time%

format-background = ${colors.background-alt}
format-foreground = ${colors.foreground}
format-padding = 2

