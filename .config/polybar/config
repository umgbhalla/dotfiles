; polybar configuration

[colors]
background = #2e3440
background-alt = #4c566a
foreground = #eceff4
primary = #ebcb8b
secondary = #81a1c1
tertiary = #a3be8c
alert = #bf616a
transparent = #00000000

[global/wm]
margin-top = 0
margin-bottom = 0

[bar/main]
width = 100%
height = 40
override-redirect = true

background = ${colors.transparent}
foreground = ${colors.foreground}

border-size = 16
border-color = ${colors.transparent}

font-0 = LiberationMono:pixelsize=12:antialias=true:autohint=true;1
;font-0 = fixed:pixelsize=10;1
;font-1 = unifont:fontformat=truetype:size=8:antialias=false;0
;font-2 = siji:pixelsize=10;1

modules-left = bspwm
;modules-center = mpd alsa pulseaudio
modules-right = wlan eth battery date

cursor-click = pointer

[module/bspwm]
type = internal/bspwm

label-focused = %index%
label-focused-background = ${colors.primary}
label-focused-foreground = ${colors.background}
label-focused-padding = 2

label-occupied = %index%
label-occupied-background = ${colors.background-alt}
label-occupied-padding = 2

label-urgent = %index%!
label-urgent-background = ${colors.alert}
label-urgent-padding = 2

label-empty = %index%
label-empty-background = ${colors.background}
label-empty-padding = 2

;[module/mpd]
;type = internal/mpd
;format-online = <label-song>  <icon-prev> <icon-stop> <toggle> <icon-next>
;
;icon-prev = 
;icon-stop = 
;icon-play = 
;icon-pause = 
;icon-next = 
;
;label-song-maxlen = 25
;label-song-ellipsis = true

[module/wlan]
type = internal/network
interface = wlp1s0
interval = 3.0

format-connected-background = ${colors.background}
format-connected-foreground = ${colors.tertiary}
format-connected-padding = 2
label-connected = %essid%

format-disconnected-background = ${colors.background}
format-disconnected-padding = 2
label-disconnected = %ifname% disconnected

[module/eth]
type = internal/network
interface = enp0s31f6
interval = 3.0

format-connected-background = ${colors.background}
format-connected-foreground = ${colors.tertiary}
label-connected = %local_ip%

format-disconnected-background = ${colors.background}
format-disconnected =

[module/date]
type = internal/date
interval = 5

date = %m/%d
time = %H:%M
label = %date% %time%

format-background = ${colors.secondary}
format-foreground = ${colors.background}
format-padding = 2

;[module/pulseaudio]
;type = internal/pulseaudio
;
;format-volume = <label-volume> <bar-volume>
;label-volume = VOL %percentage%%
;label-volume-foreground = ${root.foreground}
;
;label-muted = 🔇 muted
;label-muted-foreground = #666
;
;bar-volume-width = 10
;bar-volume-foreground-0 = #55aa55
;bar-volume-foreground-1 = #55aa55
;bar-volume-foreground-2 = #55aa55
;bar-volume-foreground-3 = #55aa55
;bar-volume-foreground-4 = #55aa55
;bar-volume-foreground-5 = #f5a70a
;bar-volume-foreground-6 = #ff5555
;bar-volume-gradient = false
;bar-volume-indicator = |
;bar-volume-indicator-font = 2
;bar-volume-fill = ─
;bar-volume-fill-font = 2
;bar-volume-empty = ─
;bar-volume-empty-font = 2
;bar-volume-empty-foreground = ${colors.foreground-alt}
;
;[module/alsa]
;type = internal/alsa
;
;format-volume = <label-volume> <bar-volume>
;label-volume = VOL
;label-volume-foreground = ${root.foreground}
;
;format-muted-prefix = " "
;format-muted-foreground = ${colors.foreground-alt}
;label-muted = sound muted
;
;bar-volume-width = 10
;bar-volume-foreground-0 = #55aa55
;bar-volume-foreground-1 = #55aa55
;bar-volume-foreground-2 = #55aa55
;bar-volume-foreground-3 = #55aa55
;bar-volume-foreground-4 = #55aa55
;bar-volume-foreground-5 = #f5a70a
;bar-volume-foreground-6 = #ff5555
;bar-volume-gradient = false
;bar-volume-indicator = |
;bar-volume-indicator-font = 2
;bar-volume-fill = ─
;bar-volume-fill-font = 2
;bar-volume-empty = ─
;bar-volume-empty-font = 2
;bar-volume-empty-foreground = ${colors.foreground-alt}

[module/battery]
type = internal/battery
battery = BAT0
adapter = ADP1
full-at = 98

format-full = <label-full>
format-full-background = ${colors.tertiary}
format-full-foreground = ${colors.background}
format-full-padding = 2

format-charging = <label-charging>
format-charging-background = ${colors.tertiary}
format-charging-foreground = ${colors.background}
format-charging-padding = 2

format-discharging = <label-discharging>
format-discharging-background = ${colors.background}
format-discharging-foreground = ${colors.foreground}
format-discharging-padding = 2

